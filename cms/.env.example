# MongoDB cho CMS — có thể tách riêng database hoặc dùng chung với bot
DATABASE_URI=mongodb://localhost:27017/skillbot_cms

# Bí mật để ký session JWT — đổi trong production
PAYLOAD_SECRET=change-me-in-production-use-a-long-random-string

# Public URL — Payload sinh URL cho file upload, AI hook đọc qua link này
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Bot's internal HTTP API — Payload hooks gọi để extract/verify file
BOT_INTERNAL_URL=http://localhost:4001
# Phải KHỚP giá trị INTERNAL_SECRET trong apps/bot/.env
INTERNAL_SECRET=change-me-internal-secret

# ─────────────────────────────────────────────────────────────
# S3 storage cho Media collection (optional)
# Để trống S3_BUCKET → Payload fallback về local disk (cms/media/)
# Điền đủ 5 biến → tự chuyển sang S3.
# ─────────────────────────────────────────────────────────────
S3_BUCKET=
S3_ENDPOINT=
# vd AWS: https://s3.ap-southeast-1.amazonaws.com
# vd MinIO/xorcloud: https://s3.xorcloud.net
# vd DigitalOcean Spaces: https://sgp1.digitaloceanspaces.com
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Default true (path-style cho MinIO/Spaces/xorcloud).
# Set `false` khi dùng AWS S3 thật (vhost-style).
# S3_FORCE_PATH_STYLE=true
